CLOUD [icon: cloud]

CLOUD-PROVIDER {
  REGION{
    FRONT-END-STATIC-HOSTING [icon: aws-s3]
    FRONT-END-SECURIZATION[icon: aws-cloudfront]
    VPC [icon: aws-vpc] {
      IGW [icon: aws-internet-gateway]
      BASTION {
        SSH-SRV [icon: debian]
      }
      DMZ {
        RPROXY-SRV [icon: nginx]
      }
      PRIVATE-SUBNET {
        DOCKER-ENGINE {
          API-GATEWAY [icon: docker]
          CONT-1 [icon: docker]
          CONT-2 [icon: docker]
          VOL-1 [icon: database]
          VOL-2 [icon: database]
        }
      }
    }
